# Copiar a .env.local (no se sube a git).

# Modo multi-empresa vos.ai (activo por defecto).
# Desactivar: VITE_PLATFORM_MODE=false
# VITE_PLATFORM_MODE=true

# URL del API — solo necesaria en build de producción o si no usás proxy Vite.
# En desarrollo (`npm run dev`) el proxy /dev-api → localhost:3000.
# VPS/Docker: debe ser la URL pública, ej. http://TU_IP:3000
# VITE_API_URL=http://localhost:3000

# WhatsApp asesor (solo build; no se muestra el número en la UI).
# VITE_LANDING_WHATSAPP_URL=https://wa.me/57XXXXXXXXXX?text=Hola

# Slug por defecto de la tienda pública (fallback si la URL no trae slug).
# VITE_SHOP_SLUG=arandano

# URL pública del front para enlaces de tienda (admin + comprobantes). En dev suele ser http://localhost:5173
# VITE_SHOP_FRONT_URL=http://localhost:5173
