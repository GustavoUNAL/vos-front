# Copia este archivo a `.env.local` y rellena los valores (`.env.local` no se sube a git).

# Modo operación: solo productos a la venta + ventas (oculta inventario, POS, finanzas, etc.).
# Valores para menú completo: false | 0 | off
# VITE_SALES_FLOOR_ONLY=false

# URL base del API (opcional en desarrollo).
# · Vacío / sin esta línea: en `npm run dev` el front usa el proxy /dev-api (misma máquina,
#   puerto 3000). Sirve para http://localhost:5173 y para http://TU_IP_LAN:5173 sin tocar CORS.
# · URL explícita: ej. http://localhost:3000 — entonces el navegador llama directo al API;
#   si abrís el front por IP de red, tenés que permitir ese origen en CORS del backend.
# VITE_API_URL=http://localhost:3000

# PostgreSQL — la usa **arandano-api** (Prisma), no el bundle del navegador.
# Formato: postgresql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
# Si Prisma dice "denied access" / "(not available)": la URL apunta a un host caído,
# credenciales malas o la BD no existe. Local: Docker + `npm run db:local:up` en el API,
# luego `npm run db:migrate` (y seed si aplica) contra esa misma DATABASE_URL.
# En Railway: la URL del plugin Postgres debe estar en el servicio que ejecuta la API.
DATABASE_URL=
