// Esquema mínimo alineado con purchase_lot_lines + inventario y lotes.
// Ajustá nombres de tablas si tu DB real difiere (p. ej. `inventory` vs `inventory_items`).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Category {
  id   String @id @default(cuid())
  name String
  type String // debe incluir INVENTORY para validar líneas de compra

  inventoryItems InventoryItem[]
  purchaseLines  PurchaseLotLine[]

  @@map("categories")
}

model PurchaseLot {
  id               String    @id @default(cuid())
  code             String    @unique
  purchaseDate     DateTime  @map("purchase_date")
  supplier         String?
  notes            String?
  totalValueCOP    Decimal?  @map("total_value_cop") @db.Decimal(18, 2)
  /** Marca manual de revisión / trazabilidad (independiente de `updated_at`). */
  traceModifiedAt  DateTime? @map("trace_modified_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  lines PurchaseLotLine[] @relation("LotLines")

  @@map("purchase_lots")
}

model InventoryItem {
  id          String    @id @default(cuid())
  name        String
  categoryId  String    @map("category_id")
  quantity    Decimal   @db.Decimal(18, 4)
  unit        String
  unitCostCOP Decimal   @map("unit_cost_cop") @db.Decimal(18, 2)
  lot         String? // código de lote → purchase_lots.code
  /** Marca manual de revisión / trazabilidad (independiente de `updated_at` del API). */
  traceModifiedAt DateTime? @map("trace_modified_at")

  category        Category         @relation(fields: [categoryId], references: [id])
  purchaseLotLine PurchaseLotLine?

  @@index([lot])
  @@map("inventory_items")
}

/// Fuente de verdad del costo de compra por línea (congelado en compra / PUT purchase-lines).
model PurchaseLotLine {
  id                   String   @id @default(cuid())
  purchaseLotCode      String   @map("purchase_lot_code")
  inventoryItemId      String?  @unique @map("inventory_item_id")
  lineName             String   @map("line_name")
  categoryId           String   @map("category_id")
  quantityPurchased    Decimal  @map("quantity_purchased") @db.Decimal(18, 4)
  unit                 String
  purchaseUnitCostCOP  Decimal  @map("purchase_unit_cost_cop") @db.Decimal(18, 2)
  lineTotalCOP         Decimal  @map("line_total_cop") @db.Decimal(18, 2)
  sortOrder            Int      @map("sort_order")

  purchaseLot   PurchaseLot    @relation("LotLines", fields: [purchaseLotCode], references: [code], onDelete: Cascade)
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  category      Category       @relation(fields: [categoryId], references: [id])

  @@index([purchaseLotCode])
  @@map("purchase_lot_lines")
}
