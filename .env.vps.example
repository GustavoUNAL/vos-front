# =============================================================================
# VOS Front — VPS Arándano (PM2 + Vite)
# =============================================================================
# Copiar en el servidor:
#   cp .env.vps.example .env.local
#   pm2 restart vos-front
#
# Vite lee .env.local en dev/preview automáticamente.
# =============================================================================

VITE_PLATFORM_MODE=true
VITE_SHOP_SLUG=arandano
VITE_BRAND_NAME=VOS AI
VITE_BRAND_TAGLINE=Sistema operativo inteligente para empresas.

# URL del API vista desde el NAVEGADOR del usuario.
#
# Opción A — IP directa (pruebas, mismo protocolo http en front y API):
VITE_API_URL=http://51.222.24.228:3001
#
# Opción B — dominio + path /backend/ (Nginx → :3001, sin subdominio api):
# VITE_API_URL=https://vos-ai.arandano.shop/backend
#
# Opción C — subdominio api (cuando exista DNS api.arandano.shop):
# VITE_API_URL=https://api.arandano.shop

# URLs públicas del front (enlaces, tienda, landing)
VITE_APP_URL=https://vos-ai.arandano.shop
VITE_LANDING_URL=https://vos-ai.arandano.shop/#/
VITE_SHOP_FRONT_URL=https://vos-ai.arandano.shop
VITE_SHOP_URL=https://vos-ai.arandano.shop/#/tienda/arandano

# WhatsApp asesor (solo build; no se muestra el número en UI)
# VITE_LANDING_WHATSAPP_URL=https://wa.me/57XXXXXXXXXX?text=Hola
